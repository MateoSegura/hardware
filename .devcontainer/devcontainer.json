{
  "name": "hardware",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "postCreateCommand": "chmod +x .devcontainer/ctl.sh && .devcontainer/ctl.sh post-create",
  "postStartCommand": "chmod +x .devcontainer/ctl.sh && .devcontainer/ctl.sh post-start",
  "runArgs": [
    "--init",
    "--env-file=.devcontainer/.env"
  ],
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/devuser/.claude,type=bind,consistency=cached",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "timonwong.shellcheck",
        "redhat.vscode-yaml",
        "github.vscode-pull-request-github",
        "eamodio.gitlens",
        "usernamehw.errorlens"
      ]
    }
  }
}
